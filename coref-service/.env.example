# Copy to `.env` (docker compose reads it automatically), then `docker compose up -d`.

COREF_MODEL=cascade           # cascade (LingMess → s2e) | lingmess | fcoref
COREF_DEVICE=cpu              # cpu or cuda:0
COREF_RESOLVE_MODE=anaphora   # anaphora or pronouns_only
COREF_PRELOAD=true            # load the model at startup

# Cascade runs LingMess first, then s2e-coref fills the mentions LingMess missed.
# The s2e checkpoint auto-downloads into /models/s2e on first start.
S2E_MODEL_PATH=/models/s2e
S2E_AUTO_DOWNLOAD=true        # set false to skip the download (falls back to LingMess)
S2E_TOKENIZER=allenai/longformer-large-4096
